@model List<AdminWorkItemListItemViewModel>
@{
    ViewData["Title"] = "Admin Work Items";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>管理後台 - Work Items</h2>
    <div>
        <a class="btn btn-primary" asp-action="Create">新增 Work Item</a>
        <a class="btn btn-outline-secondary ms-2" asp-controller="WorkItems" asp-action="Index">回前台列表</a>
    </div>
</div>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">@TempData["Message"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<table class="table table-bordered">
    <thead>
        <tr>
            <th>編號</th>
            <th>標題</th>
            <th>描述</th>
            <th>是否啟用</th>
            <th>更新時間</th>
            <th style="width: 220px;">操作</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Title</td>
                <td>@(string.IsNullOrWhiteSpace(item.Description) ? "-" : item.Description)</td>
                <td>@(item.IsActive ? "是" : "否")</td>
                <td>@(item.UpdatedAt.HasValue ? item.UpdatedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") : "-")</td>
                <td>
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">編輯</a>
                    @if (item.IsActive)
                    {
                        <form class="d-inline" method="post" asp-action="Delete" onsubmit="return confirm('確定要刪除此項目嗎？');">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button class="btn btn-sm btn-danger" type="submit">刪除</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
